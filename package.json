{
  "name": "rolelens-ai",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "rolelens": "concurrently -n backend,frontend -c blue,magenta \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && .venv/bin/python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "frontend": "npm --prefix frontend run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
